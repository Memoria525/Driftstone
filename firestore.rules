rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /cards/{cardId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    match /courses/{courseId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true
        && request.resource.data.keys().hasOnly(['name', 'isPrivate'])
        && request.resource.data.name is string
        && request.resource.data.isPrivate is bool;
    }
    match /errors/{errorId} {
      allow write: if request.auth != null
        && request.resource.data.keys().hasOnly(['userId', 'cardId', 'errorMessage', 'timestamp'])
        && request.resource.data.userId is string
        && request.resource.data.cardId is string
        && request.resource.data.errorMessage is string
        && request.resource.data.timestamp is timestamp;
      allow read, delete: if request.auth != null && request.auth.token.admin == true;
    }
    match /reviewed_cards/{cardId} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if request.auth != null && request.auth.token.admin == true
        && request.resource.data.keys().hasOnly(['cardId', 'status', 'issues', 'reviewedAt'])
        && request.resource.data.cardId is string
        && request.resource.data.status is string
        && request.resource.data.issues is list
        && request.resource.data.reviewedAt is timestamp;
    }
    match /users/{userId}/cardState/{cardId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.data.keys().hasOnly([
          'difficulty', 'stability', 'due', 'lastReview',
          'state', 'reps', 'lapses'
        ])
        && request.resource.data.difficulty is number
        && request.resource.data.stability is number
        && request.resource.data.due is timestamp
        && (request.resource.data.lastReview is timestamp || request.resource.data.lastReview == null)
        && request.resource.data.state is string
        && request.resource.data.reps is int
        && request.resource.data.lapses is int;
    }
  }
}
